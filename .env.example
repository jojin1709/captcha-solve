# ============================================
# CAPTCHA SOLVER - API Keys
# Configure at least one provider below
# ============================================

# --- AI Providers (for image/text/puzzle/audio solving) ---

# OpenAI - GPT-4o (best quality, paid)
OPENAI_API_KEY=sk-...

# Grok / xAI - Grok-2 Vision (good quality, has free tier)
XAI_API_KEY=xai-...

# OpenRouter - Access 100+ models including free ones (Recommended for free use)
# Sign up: https://openrouter.ai/keys
# Free models: google/gemini-2.5-flash, meta-llama/llama-4-scout, etc.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.5-flash

# Google Gemini - Gemini 2.5 Flash (free tier available)
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# --- 2Captcha API (for reCAPTCHA, hCaptcha, Turnstile) ---
# Sign up: https://2captcha.com/
TWOCAPTCHA_API_KEY=...

# --- Server Settings ---
SERVER_HOST=127.0.0.1
SERVER_PORT=5555
